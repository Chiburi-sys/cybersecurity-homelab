[Unit]
Description=Send Discord alert on system shutdown
DefaultDependencies=no
Before=shutdown.target reboot.target halt.target poweroff.target
Requires=network-online.target
After=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/true
ExecStop="/home/stacy/Cyber Security Portfolio/Scripts/shutdown_discord_alert.sh"
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
